# OS / Editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Environment secrets - never commit real credentials
.env
.env.local
.env.*.local

# Node (frontend)
frontend/node_modules/
frontend/.next/
frontend/dist/
frontend/build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Python (backend)
backend/**/__pycache__/
backend/*.pyc
backend/.venv/
backend/venv/
backend/*.egg-info/
backend/.pytest_cache/
backend/.mypy_cache/

# Runtime data - never commit user uploads or the local database
backend/uploaded_files/
backend/*.db
backend/*.db-journal

# Logs
*.log
